  texts:
  - type: 0
    title: "\u0E19\u0E31\u0E01\u0E25\u0E07\u0E17\u0E38\u0E19\u0E21\u0E34\u0E19\u0E34\u0E21\u0E2D\u0E25
      (\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E15\u0E48\u0E33\u0E21\u0E32\u0E01)"
    description: "\u0E41\u0E19\u0E27\u0E17\u0E32\u0E07\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19:\n\u0E40\u0E19\u0E49\u0E19\u0E1B\u0E25\u0E2D\u0E14\u0E20\u0E31\u0E22\u0E40\u0E1B\u0E47\u0E19\u0E2B\u0E25\u0E31\u0E01
      \u0E01\u0E23\u0E30\u0E08\u0E32\u0E22\u0E40\u0E07\u0E34\u0E19\u0E44\u0E1B\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E15\u0E48\u0E33
      \u0E40\u0E0A\u0E48\u0E19 \u0E17\u0E2D\u0E07 \u0E2B\u0E23\u0E37\u0E2D\u0E2D\u0E2A\u0E31\u0E07\u0E2B\u0E32
      \u0E40\u0E25\u0E37\u0E2D\u0E01\u0E25\u0E07\u0E17\u0E38\u0E19\u0E40\u0E09\u0E1E\u0E32\u0E30\u0E17\u0E35\u0E48\u0E40\u0E02\u0E49\u0E32\u0E43\u0E08\u0E14\u0E35
      \u0E44\u0E21\u0E48\u0E1B\u0E23\u0E31\u0E1A\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E1A\u0E48\u0E2D\u0E22\n\n\u0E04\u0E27\u0E23\u0E28\u0E36\u0E01\u0E29\u0E32:\n\u2022\u0E1E\u0E37\u0E49\u0E19\u0E10\u0E32\u0E19\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19\n\u2022\u0E01\u0E32\u0E23\u0E01\u0E23\u0E30\u0E08\u0E32\u0E22\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E41\u0E1A\u0E1A\u0E07\u0E48\u0E32\u0E22\n\u2022\u0E27\u0E34\u0E18\u0E35\u0E1B\u0E23\u0E30\u0E40\u0E21\u0E34\u0E19\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E2A\u0E48\u0E27\u0E19\u0E15\u0E31\u0E27\n\n\u0E04\u0E27\u0E23\u0E23\u0E30\u0E27\u0E31\u0E07:\n\u2022\u0E44\u0E21\u0E48\u0E04\u0E27\u0E23\u0E15\u0E32\u0E21\u0E01\u0E23\u0E30\u0E41\u0E2A\u0E2B\u0E27\u0E37\u0E2D\u0E2B\u0E27\u0E32\n\u2022\u0E2B\u0E25\u0E35\u0E01\u0E40\u0E25\u0E35\u0E48\u0E22\u0E07\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E1C\u0E31\u0E19\u0E1C\u0E27\u0E19\u0E2A\u0E39\u0E07
      \u0E40\u0E0A\u0E48\u0E19 \u0E04\u0E23\u0E34\u0E1B\u0E42\u0E15"
    icon: {fileID: -4012910897157855494, guid: 0132adbd732fb294999bad94ccad3cd8, type: 3}
  - type: 1
    title: "\u0E19\u0E31\u0E01\u0E25\u0E07\u0E17\u0E38\u0E19\u0E2A\u0E32\u0E22\u0E2D\u0E19\u0E38\u0E23\u0E31\u0E01\u0E29\u0E4C\u0E19\u0E34\u0E22\u0E21
      (\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E15\u0E48\u0E33)"
    description: "\u0E41\u0E19\u0E27\u0E17\u0E32\u0E07\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19:\n\u0E40\u0E19\u0E49\u0E19\u0E04\u0E27\u0E32\u0E21\u0E21\u0E31\u0E48\u0E19\u0E04\u0E07
      \u0E01\u0E33\u0E44\u0E23\u0E2A\u0E21\u0E48\u0E33\u0E40\u0E2A\u0E21\u0E2D \u0E40\u0E25\u0E37\u0E2D\u0E01\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E1E\u0E37\u0E49\u0E19\u0E10\u0E32\u0E19\u0E41\u0E02\u0E47\u0E07\u0E41\u0E23\u0E07
      \u0E40\u0E0A\u0E48\u0E19 \u0E17\u0E2D\u0E07 \u0E2B\u0E23\u0E37\u0E2D\u0E2B\u0E38\u0E49\u0E19\u0E1A\u0E25\u0E39\u0E0A\u0E34\u0E1B
      \u0E16\u0E37\u0E2D\u0E23\u0E30\u0E22\u0E30\u0E22\u0E32\u0E27\n\n\u0E04\u0E27\u0E23\u0E28\u0E36\u0E01\u0E29\u0E32:\n\u2022\u0E01\u0E32\u0E23\u0E27\u0E34\u0E40\u0E04\u0E23\u0E32\u0E30\u0E2B\u0E4C\u0E1B\u0E31\u0E08\u0E08\u0E31\u0E22\u0E1E\u0E37\u0E49\u0E19\u0E10\u0E32\u0E19
      (Fundamental)\n\u2022\u0E01\u0E32\u0E23\u0E1A\u0E23\u0E34\u0E2B\u0E32\u0E23\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E41\u0E1A\u0E1A\u0E23\u0E30\u0E22\u0E30\u0E22\u0E32\u0E27\n\u2022\u0E01\u0E32\u0E23\u0E2D\u0E48\u0E32\u0E19\u0E41\u0E19\u0E27\u0E42\u0E19\u0E49\u0E21\u0E40\u0E28\u0E23\u0E29\u0E10\u0E01\u0E34\u0E08\n\n\u0E04\u0E27\u0E23\u0E23\u0E30\u0E27\u0E31\u0E07:\n\u2022\u0E2D\u0E22\u0E48\u0E32\u0E0B\u0E37\u0E49\u0E2D\u0E40\u0E1E\u0E23\u0E32\u0E30\u0E01\u0E25\u0E31\u0E27\u0E15\u0E01\u0E23\u0E16\n\u2022\u0E23\u0E30\u0E27\u0E31\u0E07\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E17\u0E35\u0E48\u0E1C\u0E31\u0E19\u0E1C\u0E27\u0E19\u0E41\u0E23\u0E07
      \u0E42\u0E14\u0E22\u0E40\u0E09\u0E1E\u0E32\u0E30\u0E04\u0E23\u0E34\u0E1B\u0E42\u0E15"
    icon: {fileID: 2888004734922211334, guid: 2f7012e0d9451234cbef50f38885d727, type: 3}
  - type: 2
    title: "\u0E19\u0E31\u0E01\u0E1B\u0E23\u0E31\u0E1A\u0E2A\u0E21\u0E14\u0E38\u0E25\u0E41\u0E1A\u0E1A\u0E23\u0E30\u0E21\u0E31\u0E14\u0E23\u0E30\u0E27\u0E31\u0E07
      (\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E15\u0E48\u0E33\u2013\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07)"
    description: "\u0E41\u0E19\u0E27\u0E17\u0E32\u0E07\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19:\n\u0E2A\u0E21\u0E14\u0E38\u0E25\u0E23\u0E30\u0E2B\u0E27\u0E48\u0E32\u0E07\u0E04\u0E27\u0E32\u0E21\u0E1B\u0E25\u0E2D\u0E14\u0E20\u0E31\u0E22\u0E41\u0E25\u0E30\u0E01\u0E33\u0E44\u0E23
      \u0E01\u0E23\u0E30\u0E08\u0E32\u0E22\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E2B\u0E25\u0E32\u0E22\u0E41\u0E1A\u0E1A
      \u0E40\u0E0A\u0E48\u0E19 \u0E17\u0E2D\u0E07 + \u0E2B\u0E38\u0E49\u0E19 + \u0E2D\u0E2A\u0E31\u0E07\u0E2B\u0E32
      \u0E1B\u0E23\u0E31\u0E1A\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E40\u0E21\u0E37\u0E48\u0E2D\u0E08\u0E33\u0E40\u0E1B\u0E47\u0E19\n\n\u0E04\u0E27\u0E23\u0E28\u0E36\u0E01\u0E29\u0E32:\n\u2022\u0E27\u0E34\u0E18\u0E35\u0E41\u0E1A\u0E48\u0E07\u0E2A\u0E31\u0E14\u0E2A\u0E48\u0E27\u0E19\u0E1E\u0E2D\u0E23\u0E4C\u0E15\n\u2022\u0E17\u0E24\u0E29\u0E0E\u0E35\u0E2A\u0E21\u0E14\u0E38\u0E25\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u2013\u0E1C\u0E25\u0E15\u0E2D\u0E1A\u0E41\u0E17\u0E19\n\u2022\u0E01\u0E32\u0E23\u0E15\u0E34\u0E14\u0E15\u0E32\u0E21\u0E2A\u0E20\u0E32\u0E27\u0E30\u0E15\u0E25\u0E32\u0E14\n\n\u0E04\u0E27\u0E23\u0E23\u0E30\u0E27\u0E31\u0E07:\n\u2022\u0E2D\u0E22\u0E48\u0E32\u0E16\u0E37\u0E2D\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E2A\u0E39\u0E07\u0E21\u0E32\u0E01\u0E40\u0E01\u0E34\u0E19\u0E44\u0E1B\n\u2022\u0E23\u0E30\u0E27\u0E31\u0E07\u0E01\u0E32\u0E23\u0E1B\u0E23\u0E31\u0E1A\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E1A\u0E48\u0E2D\u0E22\u0E40\u0E01\u0E34\u0E19\u0E40\u0E2B\u0E15\u0E38"
    icon: {fileID: 5779624236791148888, guid: 01f5e7dcd53ce684594a4bb0efb59bd4, type: 3}
  - type: 3
    title: "\u0E19\u0E31\u0E01\u0E25\u0E07\u0E17\u0E38\u0E19\u0E2A\u0E21\u0E14\u0E38\u0E25
      (\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07)"
    description: "\u0E41\u0E19\u0E27\u0E17\u0E32\u0E07\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19:\n\u0E21\u0E35\u0E17\u0E31\u0E49\u0E07\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E1B\u0E25\u0E2D\u0E14\u0E20\u0E31\u0E22\u0E41\u0E25\u0E30\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07
      \u0E40\u0E0A\u0E48\u0E19 \u0E17\u0E2D\u0E07 + \u0E2B\u0E38\u0E49\u0E19 \u0E25\u0E07\u0E17\u0E38\u0E19\u0E15\u0E32\u0E21\u0E02\u0E49\u0E2D\u0E21\u0E39\u0E25
      \u0E21\u0E35\u0E40\u0E2B\u0E15\u0E38\u0E1C\u0E25\u0E40\u0E1B\u0E47\u0E19\u0E2B\u0E25\u0E31\u0E01\n\n\u0E04\u0E27\u0E23\u0E28\u0E36\u0E01\u0E29\u0E32:\n\u2022\u0E01\u0E32\u0E23\u0E27\u0E34\u0E40\u0E04\u0E23\u0E32\u0E30\u0E2B\u0E4C\u0E1E\u0E37\u0E49\u0E19\u0E10\u0E32\u0E19\u0E41\u0E25\u0E30\u0E40\u0E17\u0E04\u0E19\u0E34\u0E04\u0E04\u0E27\u0E1A\u0E04\u0E39\u0E48\n\u2022\u0E01\u0E32\u0E23\u0E08\u0E31\u0E14\u0E01\u0E32\u0E23\u0E1E\u0E2D\u0E23\u0E4C\u0E15\u0E41\u0E1A\u0E1A\u0E44\u0E14\u0E19\u0E32\u0E21\u0E34\u0E01\n\u2022\u0E01\u0E32\u0E23\u0E15\u0E31\u0E49\u0E07\u0E40\u0E1B\u0E49\u0E32\u0E01\u0E33\u0E44\u0E23\u0E41\u0E25\u0E30\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\n\n\u0E04\u0E27\u0E23\u0E23\u0E30\u0E27\u0E31\u0E07:\n\u2022\u0E2D\u0E22\u0E48\u0E32\u0E02\u0E22\u0E31\u0E1A\u0E2A\u0E31\u0E14\u0E2A\u0E48\u0E27\u0E19\u0E42\u0E14\u0E22\u0E43\u0E0A\u0E49\u0E2D\u0E32\u0E23\u0E21\u0E13\u0E4C\n\u2022\u0E23\u0E30\u0E27\u0E31\u0E07\u0E01\u0E32\u0E23\u0E16\u0E37\u0E2D\u0E04\u0E23\u0E2D\u0E07\u0E2A\u0E34\u0E19\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E4C\u0E1C\u0E31\u0E19\u0E1C\u0E27\u0E19\u0E42\u0E14\u0E22\u0E44\u0E21\u0E48\u0E15\u0E31\u0E49\u0E07
      Stop Loss"
    icon: {fileID: -683232811211151266, guid: bdc7d85c1de9b2e4889f017896262aa9, type: 3}
  - type: 4
    title: "\u0E19\u0E31\u0E01\u0E25\u0E07\u0E17\u0E38\u0E19\u0E40\u0E0A\u0E34\u0E07\u0E23\u0E38\u0E01
      (\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E1B\u0E32\u0E19\u0E01\u0E25\u0E32\u0E07\u2013\u0E2A\u0E39\u0E07)"
    description: "\u0E41\u0E19\u0E27\u0E17\u0E32\u0E07\u0E01\u0E32\u0E23\u0E25\u0E07\u0E17\u0E38\u0E19:\n\u0E01\u0E25\u0E49\u0E32\u0E23\u0E31\u0E1A\u0E04\u0E27\u0E32\u0E21\u0E40\u0E2A\u0E35\u0E48\u0E22\u0E07\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E1C\u0E25\u0E15\u0E2D\u0E1A\u0E41\u0E17\u0E19\u0E17\u0E35\u0E48\u0E21\u0E32\u0E01\u0E02\u0E36\u0E49\u0E19
      \u0E2A\u0E19\u0E43\u0E08\u0E2B\u0E38\u0E49\u0E19\u0E40\u0E15\u0E34\u0E1A\u0E42\u0E15
